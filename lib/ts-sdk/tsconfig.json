{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "types": ["node"],
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@tsp-output/*": ["./tsp-output/*"],
      "@common-grants/cg-grants-gov": ["../../../ts-cg-grants-gov/src/index.ts"],
      "@common-grants/sdk/*": ["./src/*"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*", "__tests__/**/*", "examples/**/*"],
  "exclude": ["node_modules", "dist", "examples/grants-gov-transforms.ts"]
}
