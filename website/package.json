{
  "name": "website",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "pnpm typespec && pnpm generate && astro dev",
    "start": "pnpm typespec && pnpm generate && astro dev",
    "build": "pnpm typespec && pnpm generate && astro build",
    "preview": "astro build && astro preview",
    "preview:wrangler": "pnpm build && wrangler dev",
    "astro": "astro",
    "typespec": "pnpm typespec:clear-output && pnpm typespec:openapi && pnpm typespec:extensions",
    "typespec:openapi": "tsp compile src/specs/main.tsp && cp tsp-output/@typespec/openapi3/** public/openapi && cp tsp-output/@typespec/json-schema/** public/schemas/yaml",
    "typespec:extensions": "tsp compile src/specs/extensions/index.tsp --emit @typespec/json-schema && mkdir -p .extension-schemas && cp tsp-output/@typespec/json-schema/** .extension-schemas",
    "typespec:clear-output": "rm -rf tsp-output && rm -rf public/schemas/yaml/* && rm -rf public/openapi/* && rm -rf .extension-schemas",
    "generate": "pnpm generate:schema-docs && pnpm generate:schema-metadata && pnpm generate:type-formatting && pnpm generate:versioned-schemas",
    "generate:schema-docs": "tsx src/scripts/generate-schema-docs.ts",
    "generate:schema-metadata": "tsx src/scripts/generate-schema-metadata.ts",
    "generate:type-formatting": "tsx src/scripts/generate-type-formatting.ts",
    "generate:versioned-schemas": "tsx src/scripts/generate-versioned-schemas.ts",
    "lint": "eslint . --fix",
    "format": "prettier --write . && tsp format .",
    "check:lint": "eslint",
    "check:format": "prettier --check . && tsp format . --check",
    "check:astro": "astro check",
    "check:spelling": "cspell .",
    "check:types": "tsc --noEmit",
    "checks": "pnpm check:lint && pnpm check:format && pnpm check:types && pnpm check:astro && pnpm check:spelling",
    "ci": "pnpm run build && pnpm run checks && pnpm run test",
    "audit:moderate": "pnpm audit --audit-level=moderate",
    "audit:high": "pnpm audit --audit-level=high",
    "audit:critical": "pnpm audit --audit-level=critical",
    "validate:schemas": "tsx src/scripts/validate-schemas.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@apidevtools/json-schema-ref-parser": "^15.3.2",
    "@astrojs/react": "^4.4.2",
    "@astrojs/starlight": "^0.37.7",
    "@jsonforms/core": "^3.7.0",
    "@jsonforms/react": "^3.7.0",
    "@jsonforms/vanilla-renderers": "^3.7.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "ajv": "^8.18.0",
    "astro": "^5.18.1",
    "js-yaml": "^4.1.1",
    "json-schema-merge-allof": "^0.8.1",
    "openapi-sampler": "^1.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.5",
    "swagger-ui-react": "^5.32.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typespec-versioning-changelog": "workspace:*"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@common-grants/core": "workspace:*",
    "@eslint/js": "^9.39.4",
    "@types/ajv": "^0.0.5",
    "@types/js-yaml": "^4.0.9",
    "@types/json-schema-merge-allof": "^0.6.5",
    "@types/node": "catalog:",
    "@types/swagger-ui-react": "^5.18.0",
    "@typespec/compiler": "catalog:",
    "@typespec/http": "catalog:",
    "@typespec/json-schema": "catalog:",
    "@typespec/openapi": "catalog:",
    "@typespec/openapi3": "catalog:",
    "@typespec/rest": "catalog:",
    "@typespec/versioning": "catalog:",
    "cspell": "^8.19.4",
    "eslint": "^10.2.0",
    "eslint-plugin-astro": "^1.6.0",
    "globals": "^15.15.0",
    "prettier": "3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "starlight-links-validator": "^0.14.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "catalog:website",
    "wrangler": "^4.77.0"
  },
  "overrides": {
    "js-yaml": "^4.1.1"
  }
}
