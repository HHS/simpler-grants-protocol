---
import {
  loadAllQuestionBankItems,
  getFilterOptions,
} from "@/lib/question-bank";
import CatalogPage from "@/layouts/CatalogPage.astro";
import QuestionCard from "@/components/question-bank/QuestionCard.astro";

const questions = await loadAllQuestionBankItems();
const { tags: allTags, entities: allEntities } = await getFilterOptions();
---

<CatalogPage
  title="Form question bank"
  description="A browsable index of reusable grant application questions with CommonGrants mappings"
  searchLabel="Search questions"
  searchPlaceholder="Search by name, description, or tags..."
  filters={[
    {
      id: "entity-filter",
      label: "Entity",
      options: allEntities,
      dataAttribute: "entity",
      placeholder: "Any entity",
    },
    {
      id: "tag-filter",
      label: "Tag",
      options: allTags,
      dataAttribute: "tags",
      placeholder: "Any tag",
    },
  ]}
  noResultsMessage="No questions match your search criteria."
  stats={[
    { count: Object.keys(questions).length, label: "questions" },
    { count: allTags.length, label: "tags" },
  ]}
>
  <p slot="intro" class="intro">
    Reusable grant application questions with built-in mappings to the
    CommonGrants data model. Browse the catalog below to find existing questions
    or learn how to define your own.
  </p>
  {
    Object.entries(questions)
      .sort(([a], [b]) => a.localeCompare(b))
      .map(([, item]) => <QuestionCard item={item} />)
  }
</CatalogPage>

<style>
  .intro {
    margin-bottom: 2rem;
    color: var(--sl-color-gray-2);
  }
</style>
