---
import { loadAllCustomFields, getFilterOptions } from "@/lib/custom-fields";
import CatalogPage from "@/layouts/CatalogPage.astro";
import CustomFieldCard from "@/components/custom-fields/CustomFieldCard.astro";

const customFields = loadAllCustomFields();
const { schemas: allSchemas, fieldTypes: allFieldTypes } = getFilterOptions();
---

<CatalogPage
  title="Custom Field Catalog"
  description="A searchable index of custom fields that extend CommonGrants base schemas"
  searchLabel="Search custom fields"
  searchPlaceholder="Search by name, description, or tags..."
  filters={[
    {
      id: "type-filter",
      label: "Type",
      options: allFieldTypes,
      dataAttribute: "fieldtype",
      placeholder: "Any type",
    },
    {
      id: "schema-filter",
      label: "Valid for",
      options: allSchemas,
      dataAttribute: "validfor",
      placeholder: "Any schema",
    },
  ]}
  noResultsMessage="No custom fields match your search criteria."
  stats={[
    { count: Object.keys(customFields).length, label: "custom fields" },
    { count: allSchemas.length, label: "supported schemas" },
    { count: allFieldTypes.length, label: "field types" },
  ]}
>
  <p slot="intro" class="intro">
    Custom fields extend CommonGrants schemas with implementation-specific data.
    Browse the registry below to find existing custom fields or learn how to
    define your own. For more context on how custom fields work and how to
    contribute new ones, see the <a href="/custom-fields/overview/"
      >custom fields overview</a
    >.
  </p>
  {
    Object.entries(customFields)
      .sort(([a], [b]) => a.localeCompare(b))
      .map(([, field]) => <CustomFieldCard field={field} />)
  }
</CatalogPage>

<style>
  .intro {
    margin-bottom: 2rem;
    color: var(--sl-color-gray-2);
  }
</style>
