---
import { loadAllPlugins, getFilterOptions } from "@/lib/plugins";
import CatalogPage from "@/layouts/CatalogPage.astro";
import PluginCatalogCard from "@/components/plugins/PluginCatalogCard.astro";

const plugins = loadAllPlugins();
const { languages: allLanguages, systems: allSystems } = getFilterOptions();
---

<CatalogPage
  title="External Plugins"
  description="External plugins that extend the CommonGrants protocol with custom fields"
  searchLabel="Search plugins"
  searchPlaceholder="Search by name, system, or language..."
  filters={[
    {
      id: "system-filter",
      label: "System",
      options: allSystems,
      dataAttribute: "system",
      placeholder: "Any system",
    },
    {
      id: "language-filter",
      label: "Language",
      options: allLanguages,
      dataAttribute: "language",
      placeholder: "Any language",
    },
  ]}
  noResultsMessage="No plugins match your search criteria."
  stats={[
    { count: plugins.length, label: "plugins" },
    { count: allSystems.length, label: "systems" },
    { count: allLanguages.length, label: "languages" },
  ]}
>
  <p slot="intro" class="intro">
    External plugins adapt third-party grant systems to the CommonGrants
    protocol. Each plugin maps system-specific data to CommonGrants objects and
    exposes custom fields for data that falls outside the base schema.
  </p>
  {plugins.map((plugin) => <PluginCatalogCard plugin={plugin} />)}
</CatalogPage>

<style>
  .intro {
    margin-bottom: 2rem;
    color: var(--sl-color-gray-2);
  }
</style>
