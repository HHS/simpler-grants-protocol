---
import type { CustomField } from "@/lib/custom-fields";

interface Props {
  field: CustomField;
}

const { field } = Astro.props;
const detailHref = `/custom-fields/${field.id}`;
---

<div
  class="field-card custom-field-card"
  data-name={field.name.toLowerCase()}
  data-description={field.description.toLowerCase()}
  data-tags={field.tags.join(",").toLowerCase()}
  data-validfor={field.validFor.join(",").toLowerCase()}
  data-fieldtype={field.fieldType.toLowerCase()}
>
  <a href={detailHref} class="card-link">
    <header class="card-header">
      <span class="card-key">{field.id}</span>
      <span class="card-arrow" aria-hidden="true">→</span>
    </header>

    <p class="card-description">
      <span class="sr-only">Description</span>
      {field.description}
    </p>

    <div class="card-type">
      <span class="sr-only">Field type</span>
      <span class="type-badge">{field.fieldType}</span>
    </div>

    <div class="card-schemas">
      <span class="sr-only">Valid for</span>
      <div class="schema-pill-list">
        {
          field.validFor.map((schema) => (
            <span class="schema-pill">{schema}</span>
          ))
        }
      </div>
    </div>
  </a>
</div>

<style>
  .custom-field-card {
    height: 100%;
  }

  .card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    box-shadow: var(--sl-shadow-sm);
    text-decoration: none;
    color: inherit;
    transition:
      background 0.15s ease,
      border-color 0.15s ease;
  }

  .card-link:hover {
    background: var(--sl-color-gray-7, var(--sl-color-gray-6));
    border-color: var(--sl-color-gray-2);
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .card-key {
    font-size: 1.125rem;
    font-weight: 600;
    font-family: monospace;
    color: var(--sl-color-white);
  }

  .card-arrow {
    font-size: 1.25rem;
    color: var(--sl-color-gray-2);
  }

  .card-type {
    margin-bottom: 0.5rem;
  }

  .type-badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: var(--sl-color-accent-low);
    color: var(--sl-color-accent-high);
    border-radius: 0.375rem;
    font-family: monospace;
    font-size: 0.875rem;
    line-height: 1;
    width: fit-content;
  }

  .card-description {
    font-size: 0.9375rem;
    color: var(--sl-color-gray-1);
    line-height: 1.5;
    margin: 0 0 0.75rem 0;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-link > .card-description,
  .card-link > .card-type,
  .card-link > .card-schemas,
  .card-link > .card-tags {
    margin-top: 0; /* override Starlight --sl-content-gap-y */
  }

  .card-schemas {
    margin-bottom: 0.75rem;
  }

  .schema-pill-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .schema-pill {
    padding: 0.375rem 0.75rem;
    background: var(--sl-color-blue-low);
    color: var(--sl-color-blue-high);
    border-radius: 0.375rem;
    font-size: 0.8125rem;
    font-family: monospace;
    font-weight: 500;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
