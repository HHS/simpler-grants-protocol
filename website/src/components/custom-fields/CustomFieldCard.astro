---
import type { CustomField } from "@/lib/custom-fields";
import CatalogCard from "@/components/catalog/CatalogCard.astro";

interface Props {
  field: CustomField;
}

const { field } = Astro.props;
const detailHref = `/custom-fields/${field.id}`;
---

<CatalogCard
  href={detailHref}
  title={field.id}
  description={field.description}
  dataAttributes={{
    name: field.name,
    description: field.description,
    tags: field.tags.join(","),
    validfor: field.validFor.join(","),
    fieldtype: field.fieldType,
  }}
>
  <div class="card-type">
    <span class="type-badge">{field.fieldType}</span>
  </div>

  <div class="card-schemas">
    <span class="sr-only">Valid for</span>
    <div class="schema-pill-list">
      {
        field.validFor.map((schema) => (
          <span class="schema-pill">{schema}</span>
        ))
      }
    </div>
  </div>
</CatalogCard>

<style>
  .card-type {
    margin-bottom: 0.5rem;
  }

  .type-badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: var(--sl-color-accent-low);
    color: var(--sl-color-accent-high);
    border-radius: 0.375rem;
    font-family: monospace;
    font-size: 0.875rem;
    line-height: 1;
    width: fit-content;
  }

  .card-schemas {
    margin-bottom: 0.75rem;
  }

  .schema-pill-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .schema-pill {
    padding: 0.375rem 0.75rem;
    background: var(--sl-color-blue-low);
    color: var(--sl-color-blue-high);
    border-radius: 0.375rem;
    font-size: 0.8125rem;
    font-family: monospace;
    font-weight: 500;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
