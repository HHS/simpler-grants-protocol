---
import type { FormItem } from "@/lib/forms";
import { Code, Tabs, TabItem, LinkButton } from "@astrojs/starlight/components";
import { JsonFormRenderer } from "@/components/forms/JsonFormRenderer";
import type { JsonSchema, VerticalLayout } from "@jsonforms/core";
import type { FormData } from "@/lib/types";
import { generateSchemaExample } from "@/lib/schema/example-generator";
import { Paths } from "@/lib/schema/paths";
import { extensionsAjv } from "@/lib/validation";

interface Props {
  item: FormItem;
}

const { item } = Astro.props;

const toJson = (data: Record<string, unknown>) =>
  JSON.stringify(data, null, 2) as string;

// Generate example data from the schema using openapi-sampler, which
// composes examples from nested $ref schemas automatically. Mirrors the
// approach used by QuestionDetails.astro so form authors can rely on
// @example decorators in their TypeSpec the same way.
const schemaRelPath = `${Paths.EXTENSION_SCHEMAS_PATH_PREFIX}/${item.schema}.yaml`;
const exampleJson = await generateSchemaExample(schemaRelPath, {
  validator: extensionsAjv,
});
const exampleData = JSON.parse(exampleJson) as FormData;

const hasOverrides =
  Object.keys(item.overrides.uiSchema ?? {}).length > 0 ||
  Object.keys(item.overrides.mappingFromCg ?? {}).length > 0 ||
  Object.keys(item.overrides.mappingToCg ?? {}).length > 0;

// Strip x-* extension fields and TypeSpec anchor fields from the raw schema
// so the Schemas tab shows a clean, standard JSON Schema. Also reorder
// top-level keys to match the conventional shape (title → description → type).
function stripExtensions(value: unknown, depth = 0): unknown {
  if (typeof value !== "object" || value === null || Array.isArray(value)) {
    return value;
  }
  const result: Record<string, unknown> = {};
  for (const [key, val] of Object.entries(value as Record<string, unknown>)) {
    if (key.startsWith("x-")) continue;
    // Drop $schema and $id at all levels — TypeSpec anchor fields, not part
    // of the user-facing schema.
    if (key === "$schema" || key === "$id") continue;
    // Drop example/examples — these are authoring aids, not part of the schema spec.
    if (key === "examples" || key === "example") continue;
    result[key] = stripExtensions(val, depth + 1);
  }
  return result;
}

const { description, type, ...rest } = stripExtensions(
  item.rawSchema,
) as Record<string, unknown>;

const cleanSchema: Record<string, unknown> = {
  title: item.label,
  ...(description !== undefined ? { description } : {}),
  ...(type !== undefined ? { type } : {}),
  ...rest,
};

// Compute stats from the UI schema and the separately composed mapping.
// Counting visible Controls in the UI schema (rather than all JSON schema
// properties) excludes fields that are intentionally hidden via HIDE rules —
// QB question types often carry extra fields that a specific form hides.
function countVisibleControls(node: Record<string, unknown>): number {
  // Skip any node (Control or layout) that is hidden — a HIDE rule on a Group
  // or Layout hides all of its children too.
  const rule = node.rule as Record<string, unknown> | undefined;
  if (rule?.effect === "HIDE") return 0;

  if (node.type === "Control") return 1;

  const elements = node.elements as Record<string, unknown>[] | undefined;
  if (!elements) return 0;
  return elements.reduce(
    (sum, el) => sum + countVisibleControls(el as Record<string, unknown>),
    0,
  );
}

/** Converts a JSON Schema scope string to a key path array.
 * e.g. "#/properties/org/properties/name" → ["org", "name"] */
function scopeToPath(scope: string): string[] {
  return scope.split("/").filter((s) => s !== "#" && s !== "properties");
}

/** Walks mappingFromCg along path and returns true if the terminal node has a
 * "field" key (simple mapping) or a "switch.field" key (switch mapping). */
function isMapped(mapping: Record<string, unknown>, path: string[]): boolean {
  let cur: unknown = mapping;
  for (const key of path) {
    if (typeof cur !== "object" || cur === null) return false;
    cur = (cur as Record<string, unknown>)[key];
  }
  if (typeof cur !== "object" || cur === null) return false;
  const obj = cur as Record<string, unknown>;
  if ("field" in obj) return true;
  const sw = obj.switch;
  return (
    typeof sw === "object" &&
    sw !== null &&
    "field" in (sw as Record<string, unknown>)
  );
}

/** Counts visible Controls whose scope has a corresponding mapping entry. */
function countMappedVisible(
  node: Record<string, unknown>,
  mapping: Record<string, unknown>,
): number {
  const rule = node.rule as Record<string, unknown> | undefined;
  if (rule?.effect === "HIDE") return 0;

  if (node.type === "Control") {
    const scope = node.scope as string | undefined;
    return scope && isMapped(mapping, scopeToPath(scope)) ? 1 : 0;
  }

  const elements = node.elements as Record<string, unknown>[] | undefined;
  if (!elements) return 0;
  return elements.reduce(
    (sum, el) =>
      sum + countMappedVisible(el as Record<string, unknown>, mapping),
    0,
  );
}

const totalQuestions = countVisibleControls(
  item.uiSchema as Record<string, unknown>,
);
const mappedFields = countMappedVisible(
  item.uiSchema as Record<string, unknown>,
  item.mappingFromCg,
);
const mappingPercentage =
  totalQuestions > 0 ? Math.round((mappedFields / totalQuestions) * 100) : 0;
---

<section class="summary-section">
  <div class="summary-content">
    <h2 class="summary-title">Summary</h2>
    <div class="summary-description">
      <p>
        {
          `${totalQuestions} total questions | ${mappingPercentage}% mapped to the CommonGrants schema`
        }
      </p>
      {item.description && <p>{item.description}</p>}
      {
        item.url && (
          <p>
            <a href={item.url} target="_blank">
              View source form details
            </a>
          </p>
        )
      }
    </div>
    <div class="summary-actions">
      <LinkButton href={`/forms/playground?src=${item.id}`} variant="primary">
        Explore in playground
      </LinkButton>
    </div>
  </div>
</section>

<h2 class="details-title">Details</h2>

<Tabs>
  <TabItem label="Form">
    <p>Sample version of the rendered form.</p>
    <JsonFormRenderer
      client:load
      schema={item.rawSchema as JsonSchema}
      uischema={item.uiSchema as unknown as VerticalLayout}
      data={exampleData}
      descriptionAbove
    />
  </TabItem>
  <TabItem label="Data">
    <details open>
      <summary>Form Data</summary>
      <p>What the form data looks like when it is submitted.</p>
      <Code lang="json" code={toJson(exampleData)} />
    </details>
  </TabItem>
  <TabItem label="Schemas">
    <details>
      <summary>JSON Schema</summary>
      <p>Provides the structure and data validation for this form.</p>
      <Code lang="json" code={toJson(cleanSchema)} />
    </details>
    <details>
      <summary>UI Schema (merged)</summary>
      <p>
        Describes how to present the form. Reflects any per-form
        <code>x-overrides.uiSchema</code> patches applied on top of the inherited
        question-bank UI schemas.
      </p>
      <Code lang="json" code={toJson(item.uiSchema)} />
    </details>
  </TabItem>
  <TabItem label="Mappings">
    <details>
      <summary>Mapping to CommonGrants</summary>
      <p>How to translate this form into the CommonGrants data model.</p>
      <Code lang="json" code={toJson(item.mappingToCg)} />
    </details>
    <details>
      <summary>Mapping from CommonGrants</summary>
      <p>
        How to pre-fill this form with data from the CommonGrants data model.
      </p>
      <Code lang="json" code={toJson(item.mappingFromCg)} />
    </details>
    {
      hasOverrides && (
        <details>
          <summary>Per-form overrides (x-overrides)</summary>
          <p>
            The raw <code>x-overrides</code> block declared on the form spec.
            Already merged into the UI schema and mappings shown above.
          </p>
          <Code
            lang="json"
            code={toJson(item.overrides as unknown as Record<string, unknown>)}
          />
        </details>
      )
    }
  </TabItem>
</Tabs>

<style>
  .summary-section {
    margin: 0;
    padding: 0;
  }

  .summary-title {
    font-size: 1.75rem !important;
    margin-bottom: 0.5rem;
  }

  .summary-content {
    margin: 0;
    padding: 0;
  }

  .summary-description {
    margin: 0 0 1.5rem 0;
  }

  .summary-actions {
    display: flex;
    gap: 0.25rem;
    flex-wrap: wrap;
    justify-content: flex-start;
    align-items: center;
    margin-bottom: 2rem;
  }

  .details-title {
    font-size: 1.75rem !important;
    margin-top: 0.25rem;
    margin-bottom: 0.5rem;
  }

  @media (max-width: 768px) {
    .summary-actions {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
