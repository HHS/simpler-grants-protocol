---
import type { Registry } from "@/lib/registries";
import { LinkButton } from "@astrojs/starlight/components";

interface Props {
  registry: Registry;
}

const { registry } = Astro.props;
const { format } = registry;

// Split the code so the badge can wrap at the colons on narrow screens.
const codeParts = registry.code.split(":");
---

<div class="registry-details">
  <!-- Summary -->
  <section class="section">
    <h2>Summary</h2>
    <p class="description">{registry.description}</p>

    <dl class="meta-list">
      <div class="meta-item">
        <dt>Code</dt>
        <dd class="code-badge">
          {
            codeParts.map((part, i) => (
              <>
                {part}
                {i < codeParts.length - 1 && (
                  <>
                    :<wbr />
                  </>
                )}
              </>
            ))
          }
        </dd>
      </div>
      <div class="meta-item">
        <dt>Applies to</dt>
        <dd>{registry.models.join(", ")}</dd>
      </div>
      <div class="meta-item">
        <dt>Kind</dt>
        <dd>{registry.kind}</dd>
      </div>
      <div class="meta-item">
        <dt>Status</dt>
        <dd>{registry.status === "base" ? "Base identifier" : "Extension"}</dd>
      </div>
      {
        registry.issuer && (
          <div class="meta-item">
            <dt>Issuer</dt>
            <dd>{registry.issuer}</dd>
          </div>
        )
      }
      {
        registry.orgIdGuide && (
          <div class="meta-item">
            <dt>org-id.guide</dt>
            <dd>{registry.orgIdGuide}</dd>
          </div>
        )
      }
    </dl>
  </section>

  <!-- Code structure -->
  <section class="section">
    <h2>Code structure</h2>
    <p class="section-description">
      The registry code is a three-part <code
        >&lt;schema&gt;:&lt;scope&gt;:&lt;prop&gt;</code
      >
      string that doubles as the map key in an identifier collection.
    </p>
    <dl class="meta-list">
      <div class="meta-item">
        <dt>Schema</dt>
        <dd class="mono">{registry.object}</dd>
      </div>
      <div class="meta-item">
        <dt>Scope</dt>
        <dd class="mono">{registry.scope}</dd>
      </div>
      <div class="meta-item">
        <dt>Property</dt>
        <dd class="mono">{registry.prop}</dd>
      </div>
    </dl>
  </section>

  <!-- Identifier format -->
  {
    format && (
      <section class="section">
        <h2>Identifier format</h2>
        {format.pattern ? (
          <div class="format-row">
            <span class="format-label">Pattern</span>
            <code class="format-value">{format.pattern}</code>
          </div>
        ) : format.format ? (
          <div class="format-row">
            <span class="format-label">Format</span>
            <code class="format-value">{format.format}</code>
          </div>
        ) : (
          <p class="section-description">
            This identifier has no fixed pattern; its format varies by issuer.
          </p>
        )}
        {format.example && (
          <div class="format-row">
            <span class="format-label">Example</span>
            <code class="format-value">{format.example}</code>
          </div>
        )}
        {format.normalization && format.normalization.length > 0 && (
          <div class="format-notes">
            <span class="format-label">Presentation &amp; validation</span>
            <ul>
              {format.normalization.map((note) => (
                <li>{note}</li>
              ))}
            </ul>
          </div>
        )}
      </section>
    )
  }

  <!-- Lookup and source -->
  {
    (registry.lookupUriTemplate || registry.source) && (
      <section class="section">
        <h2>Lookup &amp; source</h2>
        {registry.lookupUriTemplate && (
          <div class="format-row">
            <span class="format-label">Lookup template</span>
            <code class="format-value">{registry.lookupUriTemplate}</code>
          </div>
        )}
        {registry.source && (
          <p class="section-description">
            Source: <a href={registry.source}>{registry.source}</a>
          </p>
        )}
      </section>
    )
  }

  <!-- Actions -->
  <div class="actions">
    <LinkButton
      href="/registries"
      variant="secondary"
      icon="left-arrow"
      iconPlacement="start"
    >
      Back to Catalog
    </LinkButton>
  </div>
</div>

<style>
  .registry-details {
    max-width: 800px;
  }

  .section {
    margin-bottom: 2.5rem;
  }

  .section h2 {
    font-size: 1.6rem;
    color: var(--sl-color-white);
  }

  .section-description {
    color: var(--sl-color-gray-2);
    margin-bottom: 1rem;
  }

  .description {
    font-size: 1.1rem;
    color: var(--sl-color-gray-1);
    margin-bottom: 1.5rem;
  }

  dl.meta-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem 2rem;
    margin: 0;
    padding: 0;
  }

  dl.meta-list > .meta-item {
    display: block;
    margin: 0;
    padding: 0;
  }

  .meta-item dt {
    display: block;
    font-size: 0.75rem;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-gray-3);
    font-weight: normal;
    margin: 0 0 0.5rem 0;
    padding: 0;
  }

  .meta-item dd {
    display: block;
    font-size: 1rem;
    line-height: 1.5;
    color: var(--sl-color-text);
    margin: 0;
    padding: 0;
  }

  .meta-item dd.mono {
    font-family: monospace;
  }

  .meta-item dd.code-badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: var(--sl-color-accent-low);
    color: var(--sl-color-accent-high);
    border-radius: 0.375rem;
    font-family: monospace;
    font-size: 0.875rem;
    line-height: 1.4;
    width: fit-content;
    max-width: 100%;
    /* Prefer breaking at the colons (via <wbr>), fall back to anywhere. */
    overflow-wrap: anywhere;
  }

  .format-row {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .format-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-gray-3);
    min-width: 10rem;
  }

  .format-value {
    font-family: monospace;
    font-size: 0.9375rem;
    background: var(--sl-color-gray-6);
    padding: 0.25rem 0.5rem;
    border-radius: 0.375rem;
  }

  .format-notes {
    margin-top: 1rem;
  }

  .format-notes ul {
    margin: 0.5rem 0 0 0;
  }

  .actions {
    margin-top: 3rem;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
</style>
