---
import type { Plugin } from "@/lib/plugins";

interface Props {
  plugin: Plugin;
}

const { plugin } = Astro.props;
---

<div class="plugin-card">
  <div class="plugin-header">
    <a
      href={plugin.url}
      target="_blank"
      rel="noopener noreferrer"
      class="plugin-title"
    >
      {plugin.label}
      <span class="external-icon" aria-hidden="true">↗</span>
    </a>
    <span class="language-badge">{plugin.language}</span>
  </div>

  <table class="fields-table">
    <thead>
      <tr>
        <th>Field</th>
        <th>Type</th>
        <th>Supports</th>
      </tr>
    </thead>
    <tbody>
      {
        plugin.resolvedFields.map((field) => (
          <tr>
            <td>
              <code>{field.name}</code>
            </td>
            <td>
              <span class="type-badge">{field.fieldType}</span>
            </td>
            <td>
              {field.supportedObjects.map((obj) => (
                <span class="object-pill">{obj}</span>
              ))}
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>

<style>
  .plugin-card {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    padding: 1.5rem;
    background: var(--sl-color-black);
  }

  .plugin-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }

  .plugin-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--sl-color-white);
    text-decoration: none;
  }

  .plugin-title:hover {
    color: var(--sl-color-accent);
  }

  .external-icon {
    font-size: 0.875rem;
    opacity: 0.6;
  }

  .language-badge {
    padding: 0.25rem 0.625rem;
    background: var(--sl-color-accent-low);
    color: var(--sl-color-accent-high);
    border-radius: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 500;
  }

  .fields-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  .fields-table th {
    text-align: left;
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
    color: var(--sl-color-gray-2);
    font-weight: 600;
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .fields-table td {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--sl-color-gray-6);
    vertical-align: middle;
  }

  .fields-table tr:last-child td {
    border-bottom: none;
  }

  .type-badge {
    display: inline-block;
    padding: 0.25rem 0.5rem;
    background: var(--sl-color-blue-low);
    color: var(--sl-color-blue-high);
    border-radius: 0.25rem;
    font-family: monospace;
    font-size: 0.8125rem;
  }

  .object-pill {
    display: inline-block;
    padding: 0.25rem 0.5rem;
    background: var(--sl-color-green-low);
    color: var(--sl-color-green-high);
    border-radius: 0.25rem;
    font-size: 0.8125rem;
    font-family: monospace;
  }
</style>
