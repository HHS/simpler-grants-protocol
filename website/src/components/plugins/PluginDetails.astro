---
import type { Plugin } from "@/lib/plugins";
import { LinkButton } from "@astrojs/starlight/components";

interface Props {
  plugin: Plugin;
}

const { plugin } = Astro.props;
---

<div class="plugin-details">
  <!-- Summary Section -->
  <section class="section">
    <h2>Summary</h2>
    <p class="description">{plugin.description}</p>

    <dl class="meta-list">
      <div class="meta-item">
        <dt>System</dt>
        <dd>{plugin.system}</dd>
      </div>
      <div class="meta-item">
        <dt>Language</dt>
        <dd><span class="language-badge">{plugin.language}</span></dd>
      </div>
      <div class="meta-item">
        <dt>Version</dt>
        <dd>{plugin.version}</dd>
      </div>
      <div class="meta-item">
        <dt>Repository</dt>
        <dd>
          <a
            href={plugin.url}
            target="_blank"
            rel="noopener noreferrer"
            class="repo-link"
          >
            {plugin.url}
            <span aria-hidden="true">↗</span>
          </a>
        </dd>
      </div>
    </dl>
  </section>

  <!-- Custom Fields Section -->
  <section class="section">
    <h2>Custom Fields</h2>
    <p class="section-description">
      This plugin exposes {plugin.resolvedFields.length} custom fields beyond the
      CommonGrants base schema:
    </p>
    <table class="fields-table">
      <thead>
        <tr>
          <th>Field</th>
          <th>Type</th>
          <th>Supports</th>
        </tr>
      </thead>
      <tbody>
        {
          plugin.resolvedFields.map((field) => (
            <tr>
              <td>
                <a href={`/custom-fields/${field.id}`} class="field-link">
                  <code>{field.id}</code>
                </a>
              </td>
              <td>
                <span class="type-badge">{field.fieldType}</span>
              </td>
              <td>
                {field.validFor.map((schema) => (
                  <span class="object-pill">{schema}</span>
                ))}
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </section>

  <!-- Actions -->
  <div class="actions">
    <LinkButton
      href="/plugins"
      variant="secondary"
      icon="left-arrow"
      iconPlacement="start"
    >
      Back to Plugins
    </LinkButton>
    <LinkButton
      href="/custom-fields"
      variant="secondary"
      icon="external"
      iconPlacement="end"
    >
      View Custom Fields
    </LinkButton>
  </div>
</div>

<style>
  .plugin-details {
    max-width: 800px;
  }

  .section {
    margin-bottom: 2.5rem;
  }

  .section h2 {
    font-size: 1.6rem;
    color: var(--sl-color-white);
  }

  .section-description {
    color: var(--sl-color-gray-2);
    margin-bottom: 1rem;
  }

  .description {
    font-size: 1.1rem;
    color: var(--sl-color-gray-1);
    margin-bottom: 1.5rem;
  }

  dl.meta-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem 2rem;
    margin: 0;
    padding: 0;
  }

  dl.meta-list > .meta-item {
    display: block;
    margin: 0;
    padding: 0;
  }

  .meta-item dt {
    display: block;
    font-size: 0.75rem;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-gray-3);
    font-weight: normal;
    margin: 0 0 0.5rem 0;
    padding: 0;
  }

  .meta-item dd {
    display: block;
    font-size: 1rem;
    line-height: 1.5;
    color: var(--sl-color-text);
    margin: 0;
    padding: 0;
  }

  .language-badge {
    display: inline-block;
    padding: 0.25rem 0.625rem;
    background: var(--sl-color-accent-low);
    color: var(--sl-color-accent-high);
    border-radius: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 500;
  }

  .repo-link {
    color: var(--sl-color-accent);
    text-decoration: none;
    font-size: 0.9rem;
    word-break: break-all;
  }

  .repo-link:hover {
    text-decoration: underline;
  }

  .fields-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  .fields-table th {
    text-align: left;
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
    color: var(--sl-color-gray-2);
    font-weight: 600;
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .fields-table td {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--sl-color-gray-6);
    vertical-align: middle;
  }

  .fields-table tr:last-child td {
    border-bottom: none;
  }

  .field-link {
    text-decoration: none;
    color: var(--sl-color-accent);
  }

  .field-link:hover {
    text-decoration: underline;
  }

  .type-badge {
    display: inline-block;
    padding: 0.25rem 0.5rem;
    background: var(--sl-color-blue-low);
    color: var(--sl-color-blue-high);
    border-radius: 0.25rem;
    font-family: monospace;
    font-size: 0.8125rem;
  }

  .object-pill {
    display: inline-block;
    padding: 0.25rem 0.5rem;
    background: var(--sl-color-green-low);
    color: var(--sl-color-green-high);
    border-radius: 0.25rem;
    font-size: 0.8125rem;
    font-family: monospace;
  }

  .actions {
    margin-top: 3rem;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
</style>
