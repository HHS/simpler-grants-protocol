---
import type { QuestionBankItem } from "@/lib/question-bank";

interface Props {
  item: QuestionBankItem;
}

const { item } = Astro.props;
const detailHref = `/question-bank/${item.id}`;
---

<div
  class="field-card question-card"
  data-name={item.name.toLowerCase()}
  data-description={item.description.toLowerCase()}
  data-tags={item.tags.join(",").toLowerCase()}
>
  <a href={detailHref} class="card-link">
    <header class="card-header">
      <span class="card-key">{item.id}</span>
      <span class="card-arrow" aria-hidden="true">→</span>
    </header>

    <p class="card-description">
      <span class="sr-only">Description</span>
      {item.description}
    </p>

    <div class="card-tags">
      <span class="sr-only">Tags</span>
      <div class="tag-pill-list">
        {item.tags.map((tag) => <span class="tag-pill">{tag}</span>)}
      </div>
    </div>
  </a>
</div>

<style>
  .question-card {
    height: 100%;
  }

  .card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    box-shadow: var(--sl-shadow-sm);
    text-decoration: none;
    color: inherit;
    transition:
      background 0.15s ease,
      border-color 0.15s ease;
  }

  .card-link:hover {
    background: var(--sl-color-gray-7, var(--sl-color-gray-6));
    border-color: var(--sl-color-gray-2);
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .card-key {
    font-size: 1.125rem;
    font-weight: 600;
    font-family: monospace;
    color: var(--sl-color-white);
  }

  .card-arrow {
    font-size: 1.25rem;
    color: var(--sl-color-gray-2);
  }

  .card-description {
    font-size: 0.9375rem;
    color: var(--sl-color-gray-1);
    line-height: 1.5;
    margin: 0 0 0.75rem 0;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-link > .card-description,
  .card-link > .card-tags {
    margin-top: 0;
  }

  .card-tags {
    margin-bottom: 0;
  }

  .tag-pill-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .tag-pill {
    padding: 0.375rem 0.75rem;
    background: var(--sl-color-blue-low);
    color: var(--sl-color-blue-high);
    border-radius: 0.375rem;
    font-size: 0.8125rem;
    font-family: monospace;
    font-weight: 500;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
