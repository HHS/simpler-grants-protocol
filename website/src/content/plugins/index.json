    "packageUrl": "https://pypi.org/project/cg-grants-gov/",
    "repoUrl": "https://github.com/common-grants/py-cg-grants-gov",
    "fields": {
      "Opportunity": [
        "legacySerialId",
        "federalOpportunityNumber",
        "assistanceListings",
        "agency",
        "attachments",
        "federalFundingSource",
        "contactInfo",
        "additionalInfo",
        "fiscalYear",
        "costSharing"
      ]
    }
  }
