{
  "name": "common-grants-express-js-template",
  "version": "0.1.0",
  "private": true,
  "description": "CommonGrants Express.js template",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc -p .",
    "clean": "rm -rf dist generated",
    "typespec": "tsp compile src/typespec/main.tsp",
    "dev": "pnpm run typespec && tsx watch src/api/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "prepare": "pnpm run typespec && pnpm run build",
    "lint": "eslint --fix",
    "format": "prettier --write . && tsp format src/typespec",
    "check:lint": "eslint",
    "check:format": "prettier --check . && tsp format src/typespec --check",
    "checks": "pnpm run check:lint && pnpm run check:format"
  },
  "keywords": [
    "typespec",
    "api",
    "grants",
    "california"
  ],
  "author": "Agile Six",
  "license": "MIT",
  "packageManager": "pnpm@10.18.3",
  "dependencies": {
    "@common-grants/core": "^0.3.2",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "js-yaml": "^4.1.1",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.37",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@typespec/compiler": "~1.9.0",
    "@typespec/http": "~1.9.0",
    "@typespec/json-schema": "~1.9.0",
    "@typespec/openapi": "~1.9.0",
    "@typespec/openapi3": "~1.9.0",
    "@typespec/rest": "~0.79.0",
    "@typespec/versioning": "~0.79.0",
    "@vitest/eslint-plugin": "^1.6.14",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "overrides": {
      "ajv@>=6 <6.14.0": "6.14.0",
      "brace-expansion@>=1 <1.1.13": "1.1.13",
      "brace-expansion@>=2 <2.0.3": "2.0.3",
      "flatted@<3.4.0": "3.4.2",
      "minimatch@>=3 <3.1.5": "3.1.5",
      "minimatch@>=9 <9.0.9": "9.0.9",
      "path-to-regexp@>=0.1 <0.1.13": "0.1.13",
      "picomatch@>=2 <2.3.2": "2.3.2",
      "picomatch@>=4 <4.0.4": "4.0.4",
      "qs@<6.14.2": "6.14.2",
      "rollup@>=4 <4.59.0": "4.60.1",
      "tar@<7.5.10": "7.5.13",
      "yaml@>=2 <2.8.3": "2.8.3",
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0",
      "vite@>=7.0.0 <=7.3.1": ">=7.3.2",
      "vite@>=7.1.0 <=7.3.1": ">=7.3.2"
    },
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-3ppc-4f35-3m26",
        "GHSA-83g3-92jg-28cx",
        "GHSA-2g4f-4pwh-qvx6",
        "GHSA-w7fw-mjwx-w883"
      ]
    }
  }
}
