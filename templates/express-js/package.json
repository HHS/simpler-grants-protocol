{
  "name": "common-grants-express-js-template",
  "version": "0.1.0",
  "private": true,
  "description": "CommonGrants Express.js template",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc -p .",
    "clean": "rm -rf dist generated",
    "typespec": "tsp compile src/typespec/main.tsp",
    "dev": "pnpm run typespec && tsx watch src/api/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "prepare": "pnpm run typespec && pnpm run build",
    "lint": "eslint --fix",
    "format": "prettier --write . && tsp format src/typespec",
    "check:lint": "eslint",
    "check:format": "prettier --check . && tsp format src/typespec --check",
    "checks": "pnpm run check:lint && pnpm run check:format"
  },
  "keywords": [
    "typespec",
    "api",
    "grants",
    "california"
  ],
  "author": "Agile Six",
  "license": "MIT",
  "dependencies": {
    "@common-grants/core": "^0.2.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "js-yaml": "^4.1.1",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.2",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^11.0.0",
    "@typespec/compiler": "~1.11.0",
    "@typespec/http": "~1.11.0",
    "@typespec/json-schema": "~1.11.0",
    "@typespec/openapi": "~1.11.0",
    "@typespec/openapi3": "~1.11.0",
    "@typespec/rest": "~0.81.0",
    "@typespec/versioning": "~0.81.0",
    "@vitest/eslint-plugin": "^1.6.15",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-3ppc-4f35-3m26",
        "GHSA-83g3-92jg-28cx",
        "GHSA-2g4f-4pwh-qvx6",
        "GHSA-w7fw-mjwx-w883"
      ]
    }
  }
}
