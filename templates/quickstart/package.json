{
  "name": "quickstart",
  "version": "0.2.0",
  "private": true,
  "description": "CommonGrants quickstart template",
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "typespec": "tsp compile main.tsp",
    "format": "tsp format .",
    "check:format": "tsp format . --check",
    "checks": "pnpm run check:format"
  },
  "dependencies": {
    "@common-grants/core": "^0.3.2"
  },
  "devDependencies": {
    "@typespec/compiler": "~1.9.0",
    "@typespec/http": "~1.9.0",
    "@typespec/json-schema": "~1.9.0",
    "@typespec/openapi3": "~1.9.0",
    "@typespec/openapi": "~1.9.0",
    "@typespec/rest": "~0.79.0",
    "@typespec/versioning": "~0.79.0"
  },
  "pnpm": {
    "overrides": {
      "ajv@>=7 <8.18.0": "8.18.0",
      "picomatch@>=2 <2.3.2": "2.3.2",
      "qs@<6.14.2": "6.14.2",
      "tar@<7.5.10": "7.5.13",
      "yaml@>=2 <2.8.3": "2.8.3"
    }
  }
}
